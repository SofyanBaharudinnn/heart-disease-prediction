# ─── Django Security Configuration ───────────────────────────────────────────

# Secret key used for cryptographic signing. Change this to a random long string in production.
DJANGO_SECRET_KEY=change-this-to-a-very-secure-random-long-string-in-production

# Turn off debug mode in production (False)
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames/IPs for the application
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,localhost

# Enforce SSL/HTTPS redirect (set to False if SSL is handled upstream by Nginx/Apache/Cloudflare without passing HTTPS protocol)
DJANGO_SECURE_SSL_REDIRECT=True
